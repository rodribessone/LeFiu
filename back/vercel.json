{
  "routes": [
    {
      "src": "/static/(.)",
      "headers": { 
        "Cache-Control": "public, max-age=31536000, immutable",
        "X-Frame-Options": "DENY"
      },
      "continue": true
    }
  ],
  "rewrites": [
    { 
      "source": "/(.)", 
      "destination": "/index.html" 
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}